# SECRET ENV FILES (Hides your database keys/API secrets from public)
.env
.env.local
.env.*
!.env.example

# vercel
.vercel

# IDEs and environments (Hides these from other users)
/.idx/
/.vscode/
.npmrc

# DATABASE BACKUPS (Hides your SQL dump from public)
backup.sql
